{
  "manifest_version": 3,
  "name": "Right Search",
  "version": "1.0.0",
  "description": "Search selected text with custom search engines via right-click context menu",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
